<ui:FluentWindow
    x:Class="ImageMinify.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:ImageMinify.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="图片压缩工具"
    Icon="/Assets/icon.ico"
    Width="680"
    Height="520"
    MinWidth="680"
    MinHeight="520"
    ResizeMode="CanMinimize"
    FontFamily="Microsoft YaHei UI"
    FontSize="13"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Blue accent overrides -->
        <SolidColorBrush x:Key="AccentBlue" Color="#0078D4" />
        <SolidColorBrush x:Key="AccentBlueDark" Color="#106EBE" />
        <SolidColorBrush x:Key="AccentBlueLight" Color="#E6F2FB" />
        <SolidColorBrush x:Key="CardBg" Color="#FAFBFC" />
        <SolidColorBrush x:Key="SectionBorderBrush" Color="#E5E8EB" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="图片压缩工具" ShowMaximize="False" />

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,8,20,16">
            <StackPanel>

                <!-- File Selection Card -->
                <ui:CardControl Margin="0,0,0,10">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Folder24" FontSize="18" Foreground="{StaticResource AccentBlue}" Margin="0,0,8,0" />
                            <TextBlock Text="选择文件" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{Binding SelectedDirectoryDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Foreground="#666" />
                            <ui:Button
                                Grid.Column="1"
                                Appearance="Primary"
                                Content="选择目录"
                                Icon="{ui:SymbolIcon FolderOpen24}"
                                Command="{Binding SelectDirectoryCommand}"
                                Margin="10,0,0,0" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{Binding SelectedFilesDisplay}"
                                TextTrimming="CharacterEllipsis"
                                Foreground="#666" />
                            <ui:Button
                                Grid.Column="1"
                                Appearance="Secondary"
                                Content="选择文件"
                                Icon="{ui:SymbolIcon Image24}"
                                Command="{Binding SelectFilesCommand}"
                                Margin="10,0,0,0" />
                        </Grid>
                    </StackPanel>
                </ui:CardControl>

                <!-- Compression Settings Card -->
                <ui:CardControl Margin="0,0,0,10">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Options24" FontSize="18" Foreground="{StaticResource AccentBlue}" Margin="0,0,8,0" />
                            <TextBlock Text="压缩设置" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="输出格式" VerticalAlignment="Center" />
                            <ComboBox
                                Grid.Column="1"
                                Width="160"
                                HorizontalAlignment="Left"
                                SelectedValue="{Binding OutputFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem Content="保持原格式" Tag="original" />
                                <ComboBoxItem Content="JPEG" Tag="jpeg" />
                                <ComboBoxItem Content="PNG" Tag="png" />
                                <ComboBoxItem Content="WebP" Tag="webp" />
                            </ComboBox>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="JPEG 质量" VerticalAlignment="Center" />
                            <Slider
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                Minimum="1"
                                Maximum="100"
                                TickPlacement="BottomRight"
                                TickFrequency="10"
                                IsSnapToTickEnabled="False"
                                IsEnabled="{Binding IsQualityEnabled}"
                                Value="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:TextBox
                                Grid.Column="2"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                IsEnabled="{Binding IsQualityEnabled}"
                                Text="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </ui:CardControl>

                <!-- Rename Settings Card -->
                <ui:CardControl Margin="0,0,0,10">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Rename24" FontSize="18" Foreground="{StaticResource AccentBlue}" Margin="0,0,8,0" />
                            <TextBlock Text="重命名设置" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel>
                        <CheckBox
                            Margin="0,0,0,8"
                            Content="启用重命名"
                            IsChecked="{Binding IsRenameEnabled, Mode=TwoWay}" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="前缀" VerticalAlignment="Center" />
                            <ui:TextBox
                                Grid.Column="1"
                                IsEnabled="{Binding IsRenameEnabled}"
                                Text="{Binding RenamePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="分隔符" VerticalAlignment="Center" />
                            <ComboBox
                                Grid.Column="1"
                                Width="100"
                                HorizontalAlignment="Left"
                                IsEnabled="{Binding IsRenameEnabled}"
                                SelectedValue="{Binding RenameSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem Content="-" Tag="-" />
                                <ComboBoxItem Content="_" Tag="_" />
                            </ComboBox>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="起始编号" VerticalAlignment="Center" />
                            <ui:TextBox
                                Grid.Column="1"
                                Width="100"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                IsEnabled="{Binding IsRenameEnabled}"
                                Text="{Binding StartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </ui:CardControl>

                <!-- Start Button -->
                <ui:Button
                    Margin="0,0,0,10"
                    HorizontalAlignment="Stretch"
                    MinHeight="42"
                    Appearance="Primary"
                    Command="{Binding StartCompressionCommand}"
                    Content="开始压缩"
                    Icon="{ui:SymbolIcon Play24}"
                    FontSize="14"
                    FontWeight="SemiBold" />

                <!-- Progress Bar -->
                <ProgressBar
                    Height="6"
                    Margin="0,0,0,10"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding ProgressValue}"
                    Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Results DataGrid -->
                <DataGrid
                    MinHeight="100"
                    MaxHeight="200"
                    Margin="0,0,0,10"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding Results}"
                    SelectionMode="Single"
                    GridLinesVisibility="None"
                    BorderThickness="1"
                    BorderBrush="{StaticResource SectionBorderBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Binding="{Binding FileName}" Header="文件名" />
                        <DataGridTextColumn Width="100" Binding="{Binding OriginalSizeFormatted}" Header="原始大小" />
                        <DataGridTextColumn Width="100" Binding="{Binding CompressedSizeFormatted}" Header="压缩后" />
                        <DataGridTextColumn Width="80" Binding="{Binding CompressionRatioDisplay}" Header="压缩比" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Summary Card -->
                <Border
                    Background="{StaticResource AccentBlueLight}"
                    BorderBrush="{StaticResource AccentBlue}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="文件总数" FontSize="11" Foreground="#888" />
                            <TextBlock Text="{Binding Summary.TotalFilesDisplay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBlue}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="原始大小" FontSize="11" Foreground="#888" />
                            <TextBlock Text="{Binding Summary.TotalOriginalSizeDisplay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBlue}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="压缩后" FontSize="11" Foreground="#888" />
                            <TextBlock Text="{Binding Summary.TotalCompressedSizeDisplay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBlue}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="压缩比" FontSize="11" Foreground="#888" />
                            <TextBlock Text="{Binding Summary.OverallCompressionRatioDisplay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBlue}" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
