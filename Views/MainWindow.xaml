<Window
    x:Class="ImageMinify.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:ImageMinify.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="图片压缩工具"
    Width="800"
    Height="600"
    MinWidth="760"
    MinHeight="560"
    FontFamily="Microsoft YaHei UI"
    FontSize="12"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="选择文件" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{Binding SelectedDirectoryDisplay}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Grid.Column="1"
                        Width="90"
                        Margin="8,0,0,0"
                        Command="{Binding SelectDirectoryCommand}"
                        Content="选择目录" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{Binding SelectedFilesDisplay}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Grid.Column="1"
                        Width="90"
                        Margin="8,0,0,0"
                        Command="{Binding SelectFilesCommand}"
                        Content="选择文件" />
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="压缩设置" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <DockPanel Margin="0,0,0,8" LastChildFill="False">
                    <Label Width="80" Content="输出格式:" />
                    <ComboBox
                        Width="160"
                        SelectedValue="{Binding OutputFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem Content="保持原格式" Tag="original" />
                        <ComboBoxItem Content="JPEG" Tag="jpeg" />
                        <ComboBoxItem Content="PNG" Tag="png" />
                        <ComboBoxItem Content="WebP" Tag="webp" />
                    </ComboBox>
                </DockPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="JPEG质量:" />
                    <Slider
                        Grid.Column="1"
                        Margin="0,4,8,0"
                        Minimum="1"
                        Maximum="100"
                        TickPlacement="BottomRight"
                        TickFrequency="10"
                        IsSnapToTickEnabled="False"
                        IsEnabled="{Binding IsQualityEnabled}"
                        Value="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox
                        Grid.Column="2"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="{Binding IsQualityEnabled}"
                        Text="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="重命名设置" Margin="0,0,0,10">
            <StackPanel Margin="8">
                <CheckBox
                    Margin="0,0,0,8"
                    Content="启用重命名"
                    IsChecked="{Binding IsRenameEnabled, Mode=TwoWay}" />

                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Label Width="80" Content="前缀:" />
                    <TextBox
                        IsEnabled="{Binding IsRenameEnabled}"
                        Text="{Binding RenamePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <DockPanel Margin="0,0,0,8" LastChildFill="False">
                    <Label Width="80" Content="分隔符:" />
                    <ComboBox
                        Width="120"
                        IsEnabled="{Binding IsRenameEnabled}"
                        SelectedValue="{Binding RenameSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem Content="-" Tag="-" />
                        <ComboBoxItem Content="_" Tag="_" />
                    </ComboBox>
                </DockPanel>

                <DockPanel LastChildFill="False">
                    <Label Width="80" Content="起始编号:" />
                    <TextBox
                        Width="120"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsRenameEnabled}"
                        Text="{Binding StartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <Button
            Grid.Row="3"
            MinHeight="50"
            Margin="0,0,0,10"
            Command="{Binding StartCompressionCommand}"
            Content="开始压缩"
            FontSize="14"
            FontWeight="Bold" />

        <ProgressBar
            Grid.Row="4"
            Height="18"
            Margin="0,0,0,10"
            Minimum="0"
            Maximum="100"
            Value="{Binding ProgressValue}"
            Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

        <DataGrid
            Grid.Row="5"
            Margin="0,0,0,10"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding Results}"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Binding="{Binding FileName}" Header="文件名" />
                <DataGridTextColumn Width="130" Binding="{Binding OriginalSizeFormatted}" Header="原始大小" />
                <DataGridTextColumn Width="130" Binding="{Binding CompressedSizeFormatted}" Header="压缩后大小" />
                <DataGridTextColumn Width="130" Binding="{Binding CompressionRatioDisplay}" Header="压缩比例" />
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="6" Header="压缩结果汇总">
            <StackPanel Margin="8">
                <TextBlock Margin="0,0,0,4" Text="{Binding Summary.TotalFilesDisplay}" />
                <TextBlock Margin="0,0,0,4" Text="{Binding Summary.TotalOriginalSizeDisplay}" />
                <TextBlock Margin="0,0,0,4" Text="{Binding Summary.TotalCompressedSizeDisplay}" />
                <TextBlock Text="{Binding Summary.OverallCompressionRatioDisplay}" />
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
