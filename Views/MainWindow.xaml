<Window
    x:Class="ImageMinify.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:ImageMinify.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="图片压缩工具"
    Icon="pack://application:,,,/Assets/icon.ico"
    Width="800"
    Height="665"
    MinWidth="660"
    MinHeight="600"
    ResizeMode="CanMinimize"
    FontFamily="Microsoft YaHei UI"
    FontSize="12"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" Foreground="#0066CC" FontSize="13" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- No-hover flat button: custom ControlTemplate overrides WPF-UI implicit style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0078D4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Start button: accent style, no hover -->
        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="Padding" Value="14,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#005A9E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#222222" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,2" />
        </Style>
    </Window.Resources>

    <Grid Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: File selection -->
        <GroupBox Grid.Row="0" Header="选择文件">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="12" VerticalAlignment="Center" Text="{Binding SelectedDirectoryDisplay}" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource ActionButton}"
                        Command="{Binding SelectDirectoryCommand}" Content="选择目录" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="12" VerticalAlignment="Center" Text="{Binding SelectedFilesDisplay}" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource ActionButton}"
                        Command="{Binding SelectFilesCommand}" Content="选择文件" />
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Row 1: Execute -->
        <GroupBox Grid.Row="1" Header="执行操作">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource StartButton}"
                    Command="{Binding StartCompressionCommand}"
                    Content="开始压缩" />
                <ProgressBar Grid.Column="1" Height="6" Margin="12,0,0,0" VerticalAlignment="Center"
                    Minimum="0" Maximum="100"
                    Value="{Binding ProgressValue}"
                    Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </GroupBox>

        <!-- Row 2: Compression settings -->
        <GroupBox Grid.Row="2" Header="压缩设置">
            <StackPanel>
                <DockPanel Margin="0,0,0,4" LastChildFill="False">
                    <TextBlock Width="60" FontSize="12" Text="输出格式:" VerticalAlignment="Center" />
                    <ComboBox Width="84" FontSize="12"
                        SelectedValue="{Binding OutputFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="Tag">
                        <ComboBoxItem FontSize="12" Content="保持原格式" Tag="original" />
                        <ComboBoxItem FontSize="12" Content="JPEG" Tag="jpeg" />
                        <ComboBoxItem FontSize="12" Content="PNG" Tag="png" />
                        <ComboBoxItem FontSize="12" Content="WebP" Tag="webp" />
                    </ComboBox>
                </DockPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="12" Text="JPEG质量:" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Margin="0,0,6,0" Height="20" VerticalAlignment="Center"
                        Minimum="1" Maximum="100"
                        TickPlacement="BottomRight" TickFrequency="10" IsSnapToTickEnabled="False"
                        IsEnabled="{Binding IsQualityEnabled}"
                        Value="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="2" FontSize="12"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="{Binding IsQualityEnabled}"
                        Text="{Binding Quality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Row 3: Rename settings -->
        <GroupBox Grid.Row="3" Header="重命名设置">
            <StackPanel>
                <CheckBox Margin="0,0,0,4" FontSize="12" Content="启用重命名" IsChecked="{Binding IsRenameEnabled, Mode=TwoWay}" />
                <DockPanel Margin="0,0,0,4" LastChildFill="False">
                    <TextBlock Width="60" FontSize="12" Text="前缀:" VerticalAlignment="Center" />
                    <TextBox Width="120" FontSize="12"
                        IsEnabled="{Binding IsRenameEnabled}"
                        ToolTip="输入文件名前缀"
                        Text="{Binding RenamePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <DockPanel Margin="0,0,0,4" LastChildFill="False">
                    <TextBlock Width="60" FontSize="12" Text="分隔符:" VerticalAlignment="Center" />
                    <TextBox Width="40" FontSize="12"
                        MaxLength="1"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="{Binding IsRenameEnabled}"
                        Text="{Binding RenameSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock Width="60" FontSize="12" Text="起始编号:" VerticalAlignment="Center" />
                    <TextBox Width="72" FontSize="12"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="{Binding IsRenameEnabled}"
                        Text="{Binding StartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <!-- Row 4: Results table -->
        <Border Grid.Row="4" Margin="0,0,0,6" BorderBrush="#CCCCCC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#F5F5F5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource TableTextStyle}" FontWeight="Normal" Text="文件名" />
                    <TextBlock Grid.Column="1" Style="{StaticResource TableTextStyle}" FontWeight="Normal" Text="原始大小" />
                    <TextBlock Grid.Column="2" Style="{StaticResource TableTextStyle}" FontWeight="Normal" Text="压缩后大小" />
                    <TextBlock Grid.Column="3" Style="{StaticResource TableTextStyle}" FontWeight="Normal" Text="压缩比例" />
                </Grid>

                <ListBox Grid.Row="1"
                    BorderThickness="0"
                    Background="White"
                    HorizontalContentAlignment="Stretch"
                    ItemsSource="{Binding Results}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EAEAEA" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource TableTextStyle}" Text="{Binding FileName}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource TableTextStyle}" Text="{Binding OriginalSizeFormatted}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource TableTextStyle}" Text="{Binding CompressedSizeFormatted}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource TableTextStyle}" Text="{Binding CompressionRatioDisplay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Row 5: Summary -->
        <GroupBox Grid.Row="5" Header="压缩结果汇总">
            <StackPanel>
                <TextBlock FontSize="12" Margin="0,0,0,1" Text="{Binding Summary.TotalFilesDisplay}" />
                <TextBlock FontSize="12" Margin="0,0,0,1" Text="{Binding Summary.TotalOriginalSizeDisplay}" />
                <TextBlock FontSize="12" Margin="0,0,0,1" Text="{Binding Summary.TotalCompressedSizeDisplay}" />
                <TextBlock FontSize="12" Text="{Binding Summary.OverallCompressionRatioDisplay}" />
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
